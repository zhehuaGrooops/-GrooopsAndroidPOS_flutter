# Enforce LF for all text files
* text=auto eol=lf

# Generated Dart files — always LF
*.freezed.dart text eol=lf
*.gr.dart text eol=lf
*.g.dart text eol=lf

# Dart/Flutter source
*.dart text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md text eol=lf

# Binaries — no line ending conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.keystore binary
*.jks binary
